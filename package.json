{
  "name": "yggdrasight",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "pnpm --filter @yggdrasight/web start",
    "start:terminal": "MODE=terminal pnpm --filter @yggdrasight/web start",
    "start:landing": "MODE=landing pnpm --filter @yggdrasight/web start",
    "setup": "bash scripts/setup.sh",
    "up": "pnpm setup && pnpm build && pnpm start",
    "up:terminal": "pnpm setup && pnpm build && pnpm start:terminal",
    "up:landing": "pnpm setup && pnpm build && pnpm start:landing",
    "down": "docker compose down",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "feed": "ts-node -r scripts/bootstrap.js -r tsconfig-paths/register -P scripts/tsconfig.json scripts/feed.ts"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.1"
}
